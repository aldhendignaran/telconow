# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Local dev: http://localhost:3000
# Production: https://your-project.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Contentful — Settings → API keys → Content Delivery API
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# Generate: openssl rand -base64 24
# Must match the Authorization header set in the Contentful webhook
CONTENTFUL_REVALIDATE_SECRET=

# Upstash Redis — required for rate limiting on /login
# https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
